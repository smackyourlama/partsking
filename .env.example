# Rename to .env.local during development
PARTSKING_DB_PATH=./data/parts.db
PARTSKING_CACHE_TTL_HOURS=24
PARTSKING_REFRESH_TTL=6
PARTSKING_REFRESH_LIMIT=50
PARTSKING_REFRESH_LIST=./data/seed_parts.json
PARTSKING_PYTHON_BIN=python3
PARTSKING_SCRAPER_LIMIT=5
PARTSKING_ALLOWED_ORIGINS=

# Supabase configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_MIGRATION_URL=postgresql://postgres.<project-ref>:<db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require&pgbouncer=true
# Optional: use the pooled IPv4 endpoint when the default host only exposes AAAA records
SUPABASE_POOLER_HOST=
SUPABASE_POOLER_PORT=6543

# Frontend-only configuration (used during Vite builds)
# VITE_API_BASE_URL should point to the deployed API origin (e.g. https://parts.king-api.com)
VITE_API_BASE_URL=
# Provide Supabase read credentials when the static site needs to serve cached listings without the API backend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional override to match the backend cache freshness threshold.
VITE_CACHE_TTL_HOURS=24
# Leave at ./ for GitHub Pages so assets load correctly regardless of the repo path
VITE_BASE_PATH=./
